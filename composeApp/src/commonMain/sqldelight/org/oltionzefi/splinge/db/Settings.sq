CREATE TABLE IF NOT EXISTS SettingsEntity (
    id INTEGER NOT NULL PRIMARY KEY DEFAULT 1,
    userName TEXT NOT NULL DEFAULT '',
    paypalMe TEXT NOT NULL DEFAULT '',
    isSeeded INTEGER NOT NULL DEFAULT 0
);

upsertSettings:
INSERT OR REPLACE INTO SettingsEntity(id, userName, paypalMe, isSeeded)
VALUES (1, ?, ?, ?);

selectSettings:
SELECT * FROM SettingsEntity WHERE id = 1;

